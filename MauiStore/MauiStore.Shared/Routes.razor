@namespace MauiStore.Shared
@using Microsoft.AspNetCore.Components.Authorization

<CascadingAuthenticationState>

    <ErrorBoundary>
        <ChildContent>
            <Router AppAssembly="@typeof(MauiStore.Shared._Imports).Assembly">
                <Found Context="routeData">
                    <AuthorizeRouteView RouteData="routeData" DefaultLayout="typeof(Layout.MainLayout)">
                        <NotAuthorized>
                            <RedirectToLogin />
                        </NotAuthorized>
                        <Authorizing>
                            <MudProgressCircular Indeterminate="true" Class="m-4" />
                        </Authorizing>
                    </AuthorizeRouteView>

                    <FocusOnNavigate RouteData="routeData" Selector="h1" />
                </Found>

                <NotFound>
                    <LayoutView Layout="typeof(Layout.MainLayout)">
                        <MudText Typo="Typo.h6">Página no encontrada</MudText>
                    </LayoutView>
                </NotFound>
            </Router>
        </ChildContent>
        <ErrorContent>
            <LayoutView Layout="typeof(Layout.MainLayout)">
                <MudAlert Severity="Severity.Error">
                    A rendering error occurred. Please re-open the app.
                </MudAlert>
            </LayoutView>
        </ErrorContent>
    </ErrorBoundary>

</CascadingAuthenticationState>



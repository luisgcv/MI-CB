@inject NavigationManager Nav

<MudPaper Class="pa-4 my-6">
    <MudText Typo="Typo.h6" Class="mb-2">Necesitas iniciar sesión</MudText>
    <MudText Typo="Typo.body2" Class="mb-4">
        Para ver esta página debes autenticarte.
    </MudText>
    <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="GoLogin">
        Ir a la pantalla de ingreso
    </MudButton>
</MudPaper>

@code {
    private void GoLogin()
    {
        var rel = Nav.ToBaseRelativePath(Nav.Uri) ?? string.Empty;
        var returnUrl = "/" + rel;
        Nav.NavigateTo($"/Ingreso?returnUrl={Uri.EscapeDataString(returnUrl)}", false);
    }
}

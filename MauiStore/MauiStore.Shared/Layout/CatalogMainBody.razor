@inherits LayoutComponentBase
@using MauiStore.Infrastructure.Interfaces
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Components.Web
@using CbEnLinea.Api.Common.Models.Stores
@using CbEnLinea.Api.Common.Models.Categories
@using MauiStore.Shared.Services
@inject NavigationManager navigationManager
@inject IPurchasePreferenceManager purchasePreferenceManager

<style>
    html, body {
        height: 100%;
        margin: 0;
    }

    .page-bg {
        position: fixed;
        inset: 0;
        z-index: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 10px;
    }

        .page-bg::before {
            content: "";
            position: absolute;
            inset: 0;
        }

    .screen-center {
        position: relative;
        z-index: 1;
        min-height: 100dvh;
        display: grid;
        place-items: center;
        padding: clamp(6px, 3vw, 12px);
        padding-bottom: calc(env(safe-area-inset-bottom, 0) + clamp(6px, 3vw, 12px));
        width: 100%
    }

    .cb-card,
    .cbpeq-card {
        position: relative;
        z-index: 1;
        width: 100%;
        max-width: 100vw;
        padding: clamp(16px, 3vw, 26px);
        border-left: 10px solid #46a441;
        border-bottom: 10px solid #46a441;
        border-top-left-radius: 32px;
        border-top-right-radius: 90px;
        border-bottom-left-radius: 90px;
        border-bottom-right-radius: 32px;
        overflow: hidden;
        background: #ffffff;
        /* background-image: url('/images/fondoTransparente.png'); */
        background-repeat: no-repeat;
        background-position: 50% 50%;
        background-size: 100% auto;
        box-shadow: 0 10px 24px rgba(0,0,0,0.14);
    }

        .cb-card > *,
        .cbpeq-card > * {
            position: relative;
            z-index: 1;
        }

    .logo {
        display: block;
        margin-inline: auto;
        width: clamp(160px, 40vw, 360px);
        height: auto;
    }

    @@media (max-width: 480px) {
        .cb-card,
        .cbpeq-card {
            border-left-width: 6px;
            border-bottom-width: 6px;
            background-size: 55% auto;
            width: 100%;
            max-width: 100vw;
        }
    }

    @@media (min-width: 992px) {
        .cb-card,
        .cbpeq-card {
            border-left-width: 12px;
            border-bottom-width: 12px;
            background-size: 70% auto;
            width: 100%;
            max-width: 100vw;
        }
    }

    .gotham-bold {
        font-family: "Gotham Rounded", "Segoe UI", Roboto, Arial, sans-serif;
        font-weight: 700;
    }

    .appbar-mobile {
        display: flex;
    }

    .bottomnav-mobile {
        display: block;
    }

    .desktop-header-wrapper {
        display: none;
    }

    @@media (min-width: 992px) {
        .appbar-mobile {
            display: none;
        }

        .bottomnav-mobile {
            display: none !important;
        }

        .desktop-header-wrapper {
            display: block;
            width: 100%;
            margin-bottom: 12px;
        }

        .desktop-header-inner {
            width: 100%;
            margin: 0 auto;
            padding: 6px 10px 0 10px;
            font-family: "Gotham Rounded", "Segoe UI", Roboto, Arial, sans-serif;
        }

        .desktop-header-top {
            display: flex;
            align-items: center;
            justify-content: space-between;
            background-color: #ffffff;
            border-radius: 24px;
            padding: 10px 18px;
            gap: 18px;
        }

        .desktop-header-logo img {
            height: 100px;
            width: 240px;
            display: block;
        }

        .desktop-header-store-search {
            margin-left: auto;
            display: flex;
            align-items: center;
            gap: 12px;
            margin-right: 100px;
        }

        .desktop-header-store-container {
            position: relative;
        }

        .desktop-header-store {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 7px 18px;
            border-top-left-radius: 25px;
            border-top-right-radius: 10px;
            border-bottom-left-radius: 10px;
            border-bottom-right-radius: 25px;
            background-color: #2da84b;
            color: #ffffff;
            font-weight: 700;
            font-size: 0.95rem;
            white-space: nowrap;
            border: none;
            cursor: pointer;
            box-shadow: 0 4px 8px rgba(0,0,0,0.12);
        }

        .desktop-header-store-icon {
            font-size: 1.1rem;
        }

        .desktop-header-store-name {
            max-width: 150px;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .desktop-header-store-arrow {
            font-size: 0.9rem;
            margin-left: 2px;
        }

        .desktop-store-dropdown {
            position: absolute;
            top: 110%;
            left: 0;
            min-width: 220px;
            background: #ffffff;
            border-radius: 18px;
            box-shadow: 0 12px 26px rgba(0,0,0,0.18);
            padding: 6px 0;
            margin-top: 4px;
            z-index: 25;
        }

        .desktop-store-dropdown-header {
            padding: 6px 14px;
            font-size: 0.78rem;
            text-transform: uppercase;
            letter-spacing: .05em;
            color: #6b6b6b;
        }

        .desktop-store-item {
            padding: 7px 14px;
            cursor: pointer;
            display: flex;
            align-items: center;
            gap: 6px;
            font-size: 0.85rem;
        }

            .desktop-store-item:hover {
                background-color: #f5f5f5;
            }

        .desktop-store-item-name {
            font-weight: 600;
            color: #2e7d32;
        }

        .desktop-store-item-current {
            margin-left: auto;
            font-size: 0.75rem;
            color: #ff9800;
        }

        .desktop-header-search-wrapper {
            flex: 1;
            position: relative;
        }

        .desktop-header-search-input {
            width: 100%;
            border-radius: 999px;
            border: none;
            background-color: #f4f4f4;
            padding: 9px 40px 9px 16px;
            font-size: 0.88rem;
            outline: none;
            color: #555555;
        }

            .desktop-header-search-input::placeholder {
                color: #b2b2b2;
            }

        .desktop-header-search-icon {
            position: absolute;
            right: 13px;
            top: 50%;
            transform: translateY(-50%);
            font-size: 1.1rem;
            color: #b9b9b9;
        }

        .desktop-header-actions {
            display: flex;
            justify-content: flex-end;
            margin-top: 10px;
            gap: 12px;
        }

        .desktop-header-pill {
            border-top-left-radius: 25px;
            border-top-right-radius: 10px;
            border-bottom-left-radius: 10px;
            border-bottom-right-radius: 25px;
            border: none;
            font-weight: 800;
            font-size: 0.9rem;
            padding: 7px 24px;
            cursor: pointer;
            color: #ffffff;
            text-transform: uppercase;
            letter-spacing: .04em;
        }

            .desktop-header-pill.yellow {
                background-color: #f9b234;
            }

            .desktop-header-pill.red {
                background-color: #f1423a;
            }

        .desktop-nav-row {
            margin-top: 12px;
            background-color: #2da84b;
            border-top-left-radius: 30px;
            border-top-right-radius: 10px;
            border-bottom-left-radius: 10px;
            border-bottom-right-radius: 30px;
            margin-left: auto;
            margin-right: auto;
            display: flex;
            justify-content: center;
            align-items: center;
            gap: 32px;
            font-weight: 800;
            font-size: 0.95rem;
            text-transform: uppercase;
            letter-spacing: .04em;
            padding: 10px 26px;
        }

        .desktop-nav-link {
            color: #ffffff;
            text-decoration: none;
            padding: 6px 14px;
            border-radius: 999px;
            transition: background-color .15s ease, box-shadow .15s ease;
        }

            .desktop-nav-link.active,
            .desktop-nav-link:hover {
                background-color: rgba(0, 0, 0, 0.12);
                box-shadow: 0 3px 6px rgba(0,0,0,0.2);
            }

        .desktop-main-container-padding {
            padding: 6px;
        }

        .desktop-search-category-panel {
            position: absolute;
            top: calc(100% + 6px);
            left: 0;
            background: #ffffff;
            border-radius: 20px;
            box-shadow: 0 12px 30px rgba(0,0,0,0.18);
            padding: 12px 18px 16px 18px;
            min-width: 320px;
            max-width: 420px;
            z-index: 9999;
        }

        .desktop-search-category-header {
            font-size: 0.8rem;
            text-transform: uppercase;
            letter-spacing: .05em;
            color: #777777;
            margin-bottom: 6px;
            font-weight: 700;
        }

            .desktop-search-category-header span {
                color: #2da84b;
            }

        .desktop-search-category-divider {
            height: 1px;
            width: 100%;
            background-color: #e0e0e0;
            margin-bottom: 8px;
        }

        .desktop-search-category-grid {
            display: grid;
            grid-template-columns: repeat(3, minmax(0, 1fr));
            row-gap: 6px;
            column-gap: 12px;
            font-size: 0.82rem;
        }

        .desktop-search-category-item {
            display: flex;
            align-items: center;
            gap: 4px;
            cursor: pointer;
            color: #555555;
        }

            .desktop-search-category-item input[type="checkbox"] {
                width: 16px;
                height: 16px;
                cursor: pointer;
            }

            .desktop-search-category-item span {
                font-size: 0.8rem;
            }
    }
</style>

<MudLayout>
    <!-- MOBILE APPBAR -->
    <MudAppBar Elevation="0" Style="background-color:#46a441" Class="appbar-mobile">
        @if (_navigationManager.Uri.Substring(_navigationManager.BaseUri.Length) != "")
        {
            <MudIconButton Href="back" Icon="@Icons.Material.Filled.ArrowBack" Color="Color.Inherit" Edge="Edge.Start" />
        }
        else
        {
            <MudImage Src="/images/LogoHorizontal.png" Alt="Logo" Style="height:40px; margin-left:8px;" />
        }
        <MudSpacer />

        <MudIconButton Icon="@Icons.Material.TwoTone.Notifications" Color="Color.Inherit" />
        <MudIconButton Icon="@Icons.Material.TwoTone.Menu" Color="Color.Inherit" OnClick="@((e) => DrawerToggle())" />
    </MudAppBar>

    <!-- Drawer موبایل -->
    <MudDrawer @bind-Open="_drawerOpen"
               Anchor="Anchor.Left"
               Variant="@DrawerVariant.Temporary"
               ClipMode="DrawerClipMode.Never">
        <MudDrawerHeader Class="px-0 py-5">
            <MudCard Elevation="0" Class="pa-0" Square="true" Style="background-color: transparent; width: 100%;">
                <MudCardContent Class="pt-3">
                    <BrandLogo />
                    <MudDivider Class="mt-2" />
                </MudCardContent>
            </MudCard>
        </MudDrawerHeader>
        <NavMenu />
    </MudDrawer>

    @* <MudMainContent Style="background: url('/images/fondo_principal.png') center/cover no-repeat; min-height: 100dvh;"> *@
    <MudMainContent Style="background: url('/images/fondo_principal.png') center/cover no-repeat; min-height: 100dvh;">
        <MudContainer MaxWidth="MaxWidth.Large"
           Class="mt-5 mb-15 pt-0 pb-8 desktop-main-container-padding">

            <MudCard Elevation="0" Class="cb-card" Style="@((navigationManager.Uri.EndsWith("/Tienda/TiendaPrincipal") ? "padding:70!important;" : ""))">
                <MudCardContent Style="@((navigationManager.Uri.EndsWith("/Tienda/TiendaPrincipal") ? "padding:70!important;" : ""))">

                    <!-- DESKTOP HEADER INSIDE CARD -->
                    <div class="desktop-header-wrapper">
                        <div class="desktop-header-inner">
                            <div class="desktop-header-top">
                                <div class="desktop-header-logo">
                                    <img src="/images/logoSuper.png" alt="Logo" />
                                </div>

                                <div class="desktop-header-store-search">
                                    <div class="desktop-header-store-container">
                                        <button type="button"
                                                class="desktop-header-store"
                                                @onclick="ToggleStoreDropdown">
                                            <MudIcon Icon="@Icons.Material.TwoTone.Place" />
                                            <span class="desktop-header-store-name">
                                                @if (selectedStore is null)
                                                {
                                                    <text>Selecciona tu tienda</text>
                                                }
                                                else
                                                {
                                                    @selectedStore.Name
                                                }
                                            </span>
                                            <span class="desktop-header-store-arrow"><MudIcon Icon="@Icons.Material.TwoTone.ArrowDropDown" /></span>
                                        </button>

                                        @if (showStoreDropdown)
                                        {
                                            <div class="desktop-store-dropdown">
                                                <div class="desktop-store-dropdown-header">
                                                    Tiendas disponibles
                                                </div>

                                                @if (isStoresLoading)
                                                {
                                                    <div class="desktop-store-item">
                                                        <span>Cargando...</span>
                                                    </div>
                                                }
                                                else if (!string.IsNullOrWhiteSpace(storesErrorMessage))
                                                {
                                                    <div class="desktop-store-item">
                                                        <span>@storesErrorMessage</span>
                                                    </div>
                                                }
                                                else
                                                {
                                                    @foreach (var store in stores)
                                                    {
                                                        <div class="desktop-store-item"
                                                             @onclick="@(async () => await SelectStore(store))">
                                                            <span class="desktop-store-item-name">@store.Name</span>

                                                            @if (selectedStore is not null && selectedStore.Id == store.Id)
                                                            {
                                                                <span class="desktop-store-item-current">Actual</span>
                                                            }
                                                        </div>
                                                    }
                                                }
                                            </div>
                                        }
                                    </div>

                                    <div class="desktop-header-search-wrapper">
                                        <input class="desktop-header-search-input"
                                               type="text"
                                               placeholder="Busca tus productos"
                                               @bind="searchText"
                                               @bind:event="oninput"
                                               @onfocus="OnSearchFocus"
                                               @onkeydown="HandleSearchKeyDown" />
                                        <span class="desktop-header-search-icon"><MudIcon Icon="@Icons.Material.TwoTone.Search" /></span>

                                        @if (showSearchCategoryPanel && rootCategories != null && rootCategories.Count > 0)
                                        {
                                            <div class="desktop-search-category-panel">
                                                <div class="desktop-search-category-header">
                                                    BÚSQUEDA POR <span>CATEGORÍA</span>
                                                </div>
                                                <div class="desktop-search-category-divider"></div>

                                                <div class="desktop-search-category-grid">
                                                    @foreach (var cat in rootCategories)
                                                    {
                                                        var isChecked = searchSelectedCategoryIds.Contains(cat.Id);
                                                        <label class="desktop-search-category-item">
                                                            <input type="checkbox"
                                                                   checked="@isChecked"
                                                                   @onchange="(e => ToggleSearchCategory(cat.Id, e.Value))" />
                                                            <span>@cat.Name</span>
                                                        </label>
                                                    }
                                                </div>
                                            </div>
                                        }
                                    </div>
                                </div>

                                <div></div>
                            </div>

                            <div class="desktop-header-actions">
                                <button class="desktop-header-pill yellow">
                                    PRODUCTOS NUEVOS
                                </button>
                                <button class="desktop-header-pill red">
                                    PROMOCIONES
                                </button>
                            </div>

                            <div class="desktop-nav-row">
                                <NavLink href="/Tienda/TiendaPrincipal" Match="NavLinkMatch.All" class="desktop-nav-link">
                                    INICIO
                                </NavLink>

                                <AuthorizeView>
                                    <Authorized>
                                        <NavLink href="Configuracion/MiPerfil" class="desktop-nav-link">
                                            PERFIL
                                        </NavLink>
                                    </Authorized>
                                    <NotAuthorized>
                                        <NavLink href="/Ingreso?returnUrl=%2F" class="desktop-nav-link">
                                            INGRESAR
                                        </NavLink>
                                    </NotAuthorized>
                                </AuthorizeView>

                                <AuthorizeView>
                                    <Authorized>
                                        <NavLink href="Compras/MisCompras" class="desktop-nav-link">
                                            HISTORIAL DE COMPRAS
                                        </NavLink>
                                    </Authorized>
                                </AuthorizeView>

                                <NavLink href="/Tienda/Wishlist" class="desktop-nav-link">
                                    FAVORITOS
                                </NavLink>

                                <NavLink href="/Recetas" class="desktop-nav-link">
                                    RECETAS
                                </NavLink>
                            </div>
                        </div>
                    </div>

                    @ChildContent
                </MudCardContent>
            </MudCard>
        </MudContainer>

        <div class="my-5"></div>

        <!-- BOTTOM NAV موبایل -->
        <div class="bottomnav-mobile">
            <BottomNavMenu class="bottomnav-mobile">
                <BottomNavMenuItem Href="/"
                                   Icon="@Icons.Material.TwoTone.Cottage"
                                   IconColor="Color.Success"
                                   Title="Inicio" />

                <AuthorizeView>
                    <Authorized>
                        <BottomNavMenuItem Href="Compras/MisCompras"
                                           Match="NavLinkMatch.All"
                                           Icon="@Icons.Material.TwoTone.ShoppingBag"
                                           IconColor="Color.Success"
                                           Title="Mis compras" />
                    </Authorized>
                </AuthorizeView>

                <BottomNavMenuItem Href="/Tienda/TiendaPrincipal"
                                   Match="NavLinkMatch.All"
                                   Icon="@Icons.Material.TwoTone.ShoppingCart"
                                   IconColor="Color.Success"
                                   Title="Tienda" />

                <BottomNavMenuItem Href="Noticias/VerNoticias"
                                   Match="NavLinkMatch.All"
                                   Icon="@Icons.Material.TwoTone.Newspaper"
                                   IconColor="Color.Success"
                                   Title="Noticias" />

                <AuthorizeView>
                    <Authorized>
                        <BottomNavMenuItem Href="Configuracion/MiPerfil"
                                           Match="NavLinkMatch.All"
                                           Icon="@Icons.Material.TwoTone.PersonOutline"
                                           IconColor="Color.Success"
                                           Title="Mi perfil" />
                    </Authorized>
                    <NotAuthorized>
                        <BottomNavMenuItem Href="/Ingreso?returnUrl=%2F"
                                           Match="NavLinkMatch.All"
                                           Icon="@Icons.Material.TwoTone.PersonOutline"
                                           IconColor="Color.Success"
                                           Title="Ingresar" />
                    </NotAuthorized>
                </AuthorizeView>
            </BottomNavMenu>
        </div>
    </MudMainContent>
</MudLayout>

@code {
    [Parameter]
    public RenderFragment ChildContent { get; set; }

    [Parameter]
    public EventCallback OnDarkModeToggle { get; set; }

    private bool _drawerOpen = false;

    private const string RouteBack = "/back";

    // stores
    private bool isStoresLoading = true;
    private string? storesErrorMessage;
    private List<StoreDto> stores = new();
    private StoreDto? selectedStore;
    private bool showStoreDropdown;

    // search + category filter (header)
    private string searchText = string.Empty;
    private bool showSearchCategoryPanel = false;
    private List<CategoryDto> rootCategories = new();
    private HashSet<Guid> searchSelectedCategoryIds = new();

    protected override async Task OnInitializedAsync()
    {
        _navigationManager.RegisterLocationChangingHandler(LocationChangingHandler);

        await LoadSelectedStore();

        await InvokeAsync(StateHasChanged);
    }

    private void DrawerToggle()
    {
        _drawerOpen = !_drawerOpen;
    }

    private async ValueTask LocationChangingHandler(LocationChangingContext context)
    {
        bool isBackRoute = context.TargetLocation.EndsWith(RouteBack, StringComparison.OrdinalIgnoreCase);

        if (isBackRoute)
        {
            context.PreventNavigation();
            await _jsRuntime.InvokeVoidAsync("history.back");
        }
    }

    private void ToggleStoreDropdown()
    {
        showStoreDropdown = !showStoreDropdown;
    }

    private async Task LoadSelectedStore()
    {
        try
        {
            var store = await purchasePreferenceManager.GetSelectedStore();

            if (store is not null)
            {
                selectedStore = new StoreDto
                    {
                        Id = store.Value.id,
                        Name = store.Value.Name
                    };
            }
        }
        catch (InvalidOperationException ex) when (ex.Message.Contains("statically rendered"))
        {
            // prerender – ignore
        }
    }


    private async Task SelectStore(StoreDto store)
    {
        await purchasePreferenceManager.SetSelectedStore(store.Id, store.Name);
        selectedStore = store;
        showStoreDropdown = false;

        _navigationManager.NavigateTo(_navigationManager.Uri, forceLoad: true);
    }

    // search header events
    private void OnSearchFocus(FocusEventArgs _)
    {
        if (rootCategories != null && rootCategories.Count > 0)
            showSearchCategoryPanel = true;
    }

    private void HandleSearchKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            ExecuteSearchFromHeader();
        }
        else if (e.Key == "Escape")
        {
            showSearchCategoryPanel = false;
        }
    }

    private void ToggleSearchCategory(Guid id, object? value)
    {
        var isChecked = value is bool b && b;

        if (isChecked)
            searchSelectedCategoryIds.Add(id);
        else
            searchSelectedCategoryIds.Remove(id);
    }

    private void ExecuteSearchFromHeader()
    {
        var queryParts = new List<string>();

        if (!string.IsNullOrWhiteSpace(searchText))
        {
            var encoded = Uri.EscapeDataString(searchText);
            queryParts.Add($"searchTerm={encoded}");
        }

        if (searchSelectedCategoryIds.Count > 0)
        {
            var joined = string.Join("&categoryIds=", searchSelectedCategoryIds);
            queryParts.Add($"categoryIds={joined}");
        }

        var qs = queryParts.Count > 0 ? "?" + string.Join("&", queryParts) : string.Empty;

        showSearchCategoryPanel = false;

        navigationManager.NavigateTo($"/Tienda/TiendaPrincipal{qs}");
    }
}

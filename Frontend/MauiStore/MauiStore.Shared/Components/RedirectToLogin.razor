@inject NavigationManager Nav
<MudProgressCircular Indeterminate="true" Class="m-4" />

@code {
    bool _navigated;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || _navigated) return;
        _navigated = true;

        // Si ya estamos en /Ingreso, no hagas nada
        var uri = Nav.Uri ?? string.Empty;
        if (Nav.ToBaseRelativePath(uri) == "")
            return;

        // Calcula returnUrl relativo
        var rel = Nav.ToBaseRelativePath(uri);
        var returnUrl = "/" + (string.IsNullOrWhiteSpace(rel) ? "" : rel);

        // En WebView, navega después de ceder el hilo para evitar pantalla en blanco
        await Task.Yield();
        await InvokeAsync(() =>
            Nav.NavigateTo($"/?returnUrl={Uri.EscapeDataString(returnUrl)}", false)
        );
    }
}

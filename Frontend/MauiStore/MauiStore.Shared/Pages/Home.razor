@page "/home"
@layout MauiStore.Shared.Layout.MainLayoutPages
@using MudBlazor
@using MauiStore.Shared.Services
@using MauiStore.Shared.Components
@using MauiStore.Web.Services
@using System.Net.Http.Json
@inject IAuthService Auth
@inject NavigationManager Nav
@inject ITokenStorageService TokenStorageService
@inject HttpClient Http

<style>
    .menu-card {
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        cursor: pointer;
        height: 100%;
        border-radius: 16px !important;
        background: white;
        border: 1px solid rgba(70, 164, 65, 0.1);
    }

        .menu-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 12px 24px rgba(70, 164, 65, 0.15);
            border-color: rgba(70, 164, 65, 0.3);
        }

        .menu-card:active {
            transform: translateY(0px);
        }

    .welcome-icon {
        animation: fadeInDown 0.5s ease-out;
    }

    @@keyframes fadeInDown {
        from {
            opacity: 0;
            transform: translateY(-20px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
</style>

<RequireAuth ReturnUrl="/home">
    <div style="padding: 16px 20px 20px 20px;">
        <div class="d-flex flex-column align-center text-center mb-6 welcome-icon mt-n8">
            <MudImage Src="/images/logoSuper.png"
                      Alt="Compre Bien en línea"
                      Height="80"
                      Class="mb-2 logo" />

            <MudText Typo="Typo.h5" Style="color: #2c3e50;" Class="font-weight-bold mb-2">
                ¡Hola, @UserName!
            </MudText>

            <div style="background: linear-gradient(90deg, #e65c00 0%, #f39c12 100%);
                height: 3px;
                width: 50px;
                border-radius: 2px;
                margin: 8px 0;">
            </div>

            <MudText Typo="Typo.subtitle1" Style="color: #46A441; font-weight: 600;" Class="mt-3">
                ¿Qué deseas hacer hoy?
            </MudText>

            <MudText Typo="Typo.body2" Style="color: #343B3B;" Class="mt-2">
                Selecciona una opción para continuar
            </MudText>
        </div>

        <MudGrid Spacing="2" Justify="Justify.Center">
            @foreach (var menuItem in MenuItems)
            {
                <MudItem xs="12" sm="6" md="4" lg="4">
                    <MudCard Elevation="0"
                             Class="menu-card"
                             @onclick="() => NavigateTo(menuItem.Route)">
                        <MudCardContent Class="pa-4">
                            <div style="display: flex; align-items: center; gap: 16px;">
                                <div style="background: rgba(70, 164, 65, 0.1);
                                    border-radius: 12px;
                                    padding: 10px;
                                    min-width: 48px;
                                    text-align: center;">
                                    <MudIcon Icon="@menuItem.Icon"
                                             Size="Size.Medium"
                                             Style="color: #46a441;" />
                                </div>

                                <div style="flex: 1;">
                                    <MudText Typo="Typo.subtitle1" Style="color: #2c3e50; font-weight: 600;" Class="mb-1">
                                        @menuItem.Title
                                    </MudText>
                                    <MudText Typo="Typo.body2" Style="color: #95a5a6; line-height: 1.3;">
                                        @menuItem.Description
                                    </MudText>
                                </div>

                                <MudIcon Icon="@Icons.Material.Filled.ChevronRight"
                                         Size="Size.Small"
                                         Style="color: #46a441; opacity: 0.5;" />
                            </div>
                        </MudCardContent>
                    </MudCard>
                </MudItem>
            }
        </MudGrid>

        <div class="d-flex justify-center mt-6">
            <MudButton Variant="Variant.Text"
                       Color="Color.Error"
                       StartIcon="@Icons.Material.TwoTone.Logout"
                       OnClick="Logout"
                       Style="border-radius: 25px; padding: 8px 24px;">
                Cerrar sesión
            </MudButton>
        </div>
    </div>
</RequireAuth>

@code {
    private string UserName = "Juan";

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var token = await TokenStorageService.GetTokenAsync();
            if (!string.IsNullOrEmpty(token))
            {
                using var request = new HttpRequestMessage(HttpMethod.Get, "http://localhost:3000/users-information");
                request.Headers.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);

                var response = await Http.SendAsync(request);
                if (response.IsSuccessStatusCode)
                {
                    var userInfo = await response.Content.ReadFromJsonAsync<UserInfoResponse>();
                    if (userInfo != null && !string.IsNullOrEmpty(userInfo.Nombre))
                    {
                        UserName = userInfo.Nombre;
                    }
                }
            }
        }
        catch (Exception)
        {
            // Fallback en caso de error
            UserName = "Usuario";
        }
    }

    private class UserInfoResponse
    {
        public string? Nombre { get; set; }
    }

    private List<MenuItem> MenuItems = new()
    {
        new() { Title = "Artículos", Description = "Crear solicitudes y gestionar información de artículos", Icon = Icons.Material.TwoTone.Inventory, Route = "/articulos" },
        new() { Title = "Órdenes de compra", Description = "Consulta tus órdenes de compra y su estado", Icon = Icons.Material.TwoTone.ShoppingCart, Route = "/ordenes-compra" },
        new() { Title = "Pagos", Description = "Consulta tu estado de cuenta, pagos y pendientes", Icon = Icons.Material.TwoTone.Payment, Route = "/pagos" },
        new() { Title = "Contratos", Description = "Consulta y descarga tus contratos asignados", Icon = Icons.Material.TwoTone.Description, Route = "/contratos" },
        new() { Title = "Reuniones", Description = "Solicita y consulta tus reuniones con el equipo", Icon = Icons.Material.TwoTone.CalendarToday, Route = "/reuniones" },
        new() { Title = "Dinámicas comerciales", Description = "Consulta dinámicas activas y resultados", Icon = Icons.Material.TwoTone.Leaderboard, Route = "/dinamicas" }
    };

    private void NavigateTo(string route) => Nav.NavigateTo(route);

    private async Task Logout()
    {
        await Auth.LogoutAsync();
        Nav.NavigateTo("/", forceLoad: true);
    }

    private class MenuItem
    {
        public string Title { get; set; } = "";
        public string Description { get; set; } = "";
        public string Icon { get; set; } = "";
        public string Route { get; set; } = "";
    }
}
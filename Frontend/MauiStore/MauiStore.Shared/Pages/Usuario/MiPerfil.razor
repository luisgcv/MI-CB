@page "/Configuracion/MiPerfil"
@layout MauiStore.Shared.Layout.MainLayoutPages

@attribute [Authorize]

@inject ProfileService profileService
@inject ISnackbar Snackbar

@using MauiStore.Shared.Models.Profile
@using MauiStore.Shared.Services
@using Microsoft.AspNetCore.Authorization
@using MudBlazor

<style>
    .mud-tab {
        min-width: 90px !important;
    }

    .page-wrap {
        padding: 16px;
        max-width: 900px;
        margin: 0 auto;
        box-sizing: border-box;
        padding-top: calc(4px + env(safe-area-inset-top));
        padding-bottom: calc(16px + env(safe-area-inset-bottom) + var(--app-bottom-bar));
    }

    .profile-tabs {
        background: white;
        border-radius: 16px;
        overflow: hidden;
        box-shadow: 0 4px 20px rgba(0,0,0,0.10);
    }

        .profile-tabs .mud-tabs-panels {
            overflow-y: auto;
            -webkit-overflow-scrolling: touch;
        }

    .section-title-personal {
        color: #46a441;
        font-weight: 700;
        font-size: 1.1rem;
        margin-bottom: 12px;
        margin-top: 4px;
    }

    .section-title-org {
        color: #e65c00;
        font-weight: 700;
        font-size: 1.1rem;
        margin-bottom: 12px;
        margin-top: 16px;
    }

    @@media (max-height: 740px) {
        .page-wrap {
            padding: 12px;
            padding-top: calc(12px + env(safe-area-inset-top));
            padding-bottom: 128px;
        }
    }
</style>

<RequireAuth ReturnUrl="/Configuracion/MiPerfil">
    <div class="page-wrap">

        <MudTabs Rounded="true" PanelClass="pa-4" Class="profile-tabs">

            <!-- ── TAB: Mi Perfil ── -->
            <MudTabPanel Text="Mi Perfil">

                @if (isLoading)
                {
                    <MudProgressCircular Indeterminate="true" />
                }
                else
                {
                    <MudForm @ref="profileForm">

                        <!-- Información personal -->
                        <div class="section-title-personal">Información personal</div>

                        <MudGrid Spacing="2">

                            <MudItem xs="12">
                                <MudTextField T="string"
                                              Label="Nombre completo"
                                              Value="@profile.Name"
                                              ReadOnly="true"
                                              Variant="Variant.Outlined"
                                              Adornment="Adornment.End"
                                              AdornmentIcon="@Icons.Material.Filled.Lock"
                                              AdornmentColor="Color.Default" />
                            </MudItem>

                            <MudItem xs="12">
                                <MudTextField Label="Identificación"
                                              Value="@profile.IdentificationNumber"
                                              ReadOnly="true"
                                              Variant="Variant.Outlined"
                                              Adornment="Adornment.End"
                                              AdornmentIcon="@Icons.Material.Filled.Lock"
                                              AdornmentColor="Color.Default" />
                            </MudItem>

                            <MudItem xs="12">
                                <MudTextField T="string"
                                              Label="Correo electrónico"
                                              @bind-Value="profile.Email"
                                              Variant="Variant.Outlined"
                                              Adornment="Adornment.End"
                                              AdornmentIcon="@Icons.Material.Filled.Edit"
                                              AdornmentColor="Color.Default" />
                            </MudItem>

                            <MudItem xs="12">
                                <MudTextField T="string"
                                              Label="Teléfono"
                                              @bind-Value="profile.Phone"
                                              Variant="Variant.Outlined"
                                              Adornment="Adornment.End"
                                              AdornmentIcon="@Icons.Material.Filled.Edit"
                                              AdornmentColor="Color.Default" />
                            </MudItem>

                        </MudGrid>

                        <!-- Información organizacional -->
                        <div class="section-title-org">Información organizacional</div>

                        <MudGrid Spacing="2">

                            <MudItem xs="12">
                                <MudTextField Label="Empresa"
                                              Value="@profile.Company"
                                              ReadOnly="true"
                                              Variant="Variant.Outlined"
                                              Adornment="Adornment.End"
                                              AdornmentIcon="@Icons.Material.Filled.Lock"
                                              AdornmentColor="Color.Default" />
                            </MudItem>

                            <MudItem xs="12">
                                <MudTextField Label="Departamento"
                                              Value="@profile.Department"
                                              ReadOnly="true"
                                              Variant="Variant.Outlined"
                                              Adornment="Adornment.End"
                                              AdornmentIcon="@Icons.Material.Filled.Lock"
                                              AdornmentColor="Color.Default" />
                            </MudItem>

                            <MudItem xs="12">
                                <MudTextField Label="Puesto"
                                              Value="@profile.Position"
                                              ReadOnly="true"
                                              Variant="Variant.Outlined"
                                              Adornment="Adornment.End"
                                              AdornmentIcon="@Icons.Material.Filled.Lock"
                                              AdornmentColor="Color.Default" />
                            </MudItem>

                            <MudItem xs="12">
                                <MudButton Variant="Variant.Filled"
                                           Color="Color.Primary"
                                           FullWidth="true"
                                           OnClick="SaveProfile"
                                           Disabled="isSaving"
                                           Style="border-radius: 25px; padding: 10px;">
                                    @if (isSaving)
                                    {
                                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                            <MudProgressCircular Size="Size.Small" Indeterminate="true" />
                                            <span>Guardando...</span>
                                        </MudStack>
                                    }
                                    else
                                    {
                                        <span>Guardar</span>
                                    }
                                </MudButton>
                            </MudItem>

                        </MudGrid>

                    </MudForm>
                }

            </MudTabPanel>

            <!-- ── TAB: Cambiar Contraseña ── -->
            <MudTabPanel Text="Cambiar Contraseña">

                <MudForm @ref="passwordForm">

                    <div class="section-title-personal">Cambiar contraseña</div>

                    <MudGrid Spacing="2">

                        <MudItem xs="12">
                            <MudTextField T="string"
                                          Label="Contraseña actual"
                                          InputType="InputType.Password"
                                          @bind-Value="passwordModel.CurrentPassword"
                                          Required="true"
                                          Variant="Variant.Outlined" />
                        </MudItem>

                        <MudItem xs="12">
                            <MudTextField T="string"
                                          Label="Nueva contraseña"
                                          InputType="InputType.Password"
                                          @bind-Value="passwordModel.NewPassword"
                                          Required="true"
                                          Variant="Variant.Outlined" />
                        </MudItem>

                        <MudItem xs="12">
                            <MudTextField T="string"
                                          Label="Confirmar contraseña"
                                          InputType="InputType.Password"
                                          @bind-Value="confirmPassword"
                                          Required="true"
                                          Variant="Variant.Outlined" />
                        </MudItem>

                        <MudItem xs="12">
                            <MudButton Variant="Variant.Filled"
                                       Color="Color.Primary"
                                       FullWidth="true"
                                       OnClick="ChangePassword"
                                       Disabled="isChangingPassword"
                                       Style="border-radius: 25px; padding: 10px;">
                                @if (isChangingPassword)
                                {
                                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                        <MudProgressCircular Size="Size.Small" Indeterminate="true" />
                                        <span>Guardando...</span>
                                    </MudStack>
                                }
                                else
                                {
                                    <span>Guardar</span>
                                }
                            </MudButton>
                        </MudItem>

                    </MudGrid>

                </MudForm>

            </MudTabPanel>

        </MudTabs>

    </div>
</RequireAuth>

@code {

    private MudForm? profileForm;
    private MudForm? passwordForm;

    private bool isLoading = true;
    private bool isSaving = false;
    private bool isChangingPassword = false;

    private GetProfileResponse profile = new();
    private ChangePasswordRequest passwordModel = new();
    private string confirmPassword = "";

    protected override async Task OnInitializedAsync()
    {
        await Task.WhenAll(LoadProfile());
    }

    private async Task LoadProfile()
    {
        isLoading = true;

        var result = await profileService.GetProfileAsync();

        if (!result.Success || result.Data is null)
        {
            Snackbar.Add(result.Message ?? "Error al cargar perfil", Severity.Error);
        }
        else
        {
            profile = new GetProfileResponse
            {
                IdentificationNumber = result.Data.IdentificationNumber,
                Name = result.Data.Name,
                Phone = result.Data.Phone,
                Email = result.Data.Email,
                Company = result.Data.Company,
                Department = result.Data.Department,
                Position = result.Data.Position
            };
        }

        isLoading = false;
    }

    private async Task SaveProfile()
    {
        if (profileForm is null) return;

        await profileForm.Validate();
        if (!profileForm.IsValid) return;

        isSaving = true;
        await Task.Yield();

        var result = await profileService.UpdateProfileAsync(new UpdateProfileRequest
        {
            Name = profile.Name,
            Phone = profile.Phone
        });

        Snackbar.Add(
            result.Success ? "Perfil actualizado correctamente" : result.Message ?? "Error al actualizar",
            result.Success ? Severity.Success : Severity.Error
        );

        isSaving = false;
    }

    private async Task ChangePassword()
    {
        if (passwordForm is null) return;

        await passwordForm.Validate();
        if (!passwordForm.IsValid) return;

        if (passwordModel.NewPassword != confirmPassword)
        {
            Snackbar.Add("Las contraseñas no coinciden", Severity.Warning);
            return;
        }

        isChangingPassword = true;

        var result = await profileService.ChangePasswordAsync(passwordModel);

        if (!result.Success)
        {
            Snackbar.Add(result.Message ?? "Error al cambiar contraseña", Severity.Error);
        }
        else
        {
            Snackbar.Add("Contraseña cambiada correctamente", Severity.Success);
            passwordModel = new();
            confirmPassword = "";
        }

        isChangingPassword = false;
    }
}

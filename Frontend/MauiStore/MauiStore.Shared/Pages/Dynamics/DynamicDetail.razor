@page "/dinamicas/{Id}"
@using MudBlazor
@using MauiStore.Shared.Layout
@using MauiStore.Shared.Services
@using MauiStore.Shared.Models.Dynamics
@inject DynamicsService DynamicsService
@inject NavigationManager Nav

@layout MainLayoutPages

<RequireAuth ReturnUrl="/dinamicas">
    <div class="pa-4">

        <MudButton Variant="Variant.Text"
                   StartIcon="@Icons.Material.Filled.ArrowBack"
                   OnClick="@(() => Nav.NavigateTo("/dinamicas"))">
            Volver
        </MudButton>

        @if (_isLoading)
        {
            <div class="d-flex justify-center mt-6">
                <MudProgressCircular Size="Size.Large" Indeterminate="true" />
            </div>
        }
        else if (_hasError)
        {
            <MudAlert Severity="Severity.Error">@_errorMessage</MudAlert>
        }
        else if (_detail is not null)
        {   //Articulos particpantes
            <MudPaper Class="pa-4 mb-4 elevation-1" Style="border-radius: 12px;">
                <MudText Typo="Typo.h5" Style="color:#2e7d32;">
                    Detalle de dinámica @_detail.Id
                </MudText>

                <MudText Typo="Typo.body2" Color="Color.Secondary">
                    @_detail.Type
                </MudText>

                <MudGrid Class="mt-3">
                    <MudItem xs="6">
                        <MudText Typo="Typo.caption">Sucursal</MudText>
                        <MudText>@_detail.Branch</MudText>
                    </MudItem>

                    <MudItem xs="6">
                        <MudText Typo="Typo.caption">Monto total</MudText>
                        <MudText>₡@_detail.Total.ToString("N0")</MudText>
                    </MudItem>

                    <MudItem xs="6">
                        <MudText Typo="Typo.caption">Inicio</MudText>
                        <MudText>@_detail.StartDate.ToString("dd/MM/yyyy")</MudText>
                    </MudItem>

                    <MudItem xs="6">
                        <MudText Typo="Typo.caption">Fin</MudText>
                        <MudText>@_detail.EndDate.ToString("dd/MM/yyyy")</MudText>
                    </MudItem>
                </MudGrid>
            </MudPaper>
            //Tarjetas
            <MudGrid Class="mb-4">
                <MudItem xs="12" sm="3">
                    <MudPaper Class="pa-4 text-center" Style="border-radius: 12px;">
                        <MudText Typo="Typo.caption">Artículos</MudText>
                        <MudText Typo="Typo.h5" Style="color:#2e7d32;">
                            @_detail.Results.TotalArticles
                        </MudText>
                    </MudPaper>
                </MudItem>

                <MudItem xs="12" sm="3">
                    <MudPaper Class="pa-4 text-center" Style="border-radius: 12px;">
                        <MudText Typo="Typo.caption">Cantidad total</MudText>
                        <MudText Typo="Typo.h5" Style="color:#2e7d32;">
                            @_detail.Results.TotalQuantity.ToString("N0")
                        </MudText>
                    </MudPaper>
                </MudItem>

                <MudItem xs="12" sm="3">
                    <MudPaper Class="pa-4 text-center" Style="border-radius: 12px;">
                        <MudText Typo="Typo.caption">Monto aplicado</MudText>
                        <MudText Typo="Typo.h5" Style="color:#2e7d32;">
                            ₡@_detail.Results.TotalApplied.ToString("N0")
                        </MudText>
                    </MudPaper>
                </MudItem>

                <MudItem xs="12" sm="3">
                    <MudPaper Class="pa-4 text-center" Style="border-radius: 12px;">
                        <MudText Typo="Typo.caption">Promedio por artículo</MudText>
                        <MudText Typo="Typo.h5" Style="color:#2e7d32;">
                            ₡@_detail.Results.AverageAmount.ToString("N0")
                        </MudText>
                    </MudPaper>
                </MudItem>
            </MudGrid>

            <MudPaper Class="pa-4 elevation-1" Style="border-radius: 12px;">
                <MudText Typo="Typo.h6" Class="mb-3">
                    Artículos participantes
                </MudText>

                @if (!_detail.Lines.Any())
                {
                    <MudText Color="Color.Secondary">
                        No hay artículos asociados.
                    </MudText>
                }
                else
                {
                    <MudTable Items="_detail.Lines" Dense="true" Hover="true">
                        <HeaderContent>
                            <MudTh>SKU</MudTh>
                            <MudTh>Descripción</MudTh>
                            <MudTh>Cantidad</MudTh>
                            <MudTh>Monto</MudTh>
                        </HeaderContent>

                        <RowTemplate>
                            <MudTd>@context.Sku</MudTd>
                            <MudTd>@context.Description</MudTd>
                            <MudTd>@context.Quantity.ToString("N0")</MudTd>
                            <MudTd>₡@context.Amount.ToString("N0")</MudTd>
                        </RowTemplate>
                    </MudTable>
                }
            </MudPaper>
        }
    </div>
</RequireAuth>

@code {
    [Parameter]
    public string Id { get; set; } = string.Empty;

    private bool _isLoading;
    private bool _hasError;
    private string _errorMessage = string.Empty;

    private DynamicDetailDto? _detail;

    protected override async Task OnInitializedAsync()
    {
        _isLoading = true;

        var result = await DynamicsService.GetDynamicDetailAsync(Id);

        if (result.Success && result.Data is not null)
        {
            _detail = result.Data;
        }
        else
        {
            _hasError = true;
            _errorMessage = result.Message ?? "No se pudo cargar el detalle.";
        }

        _isLoading = false;
    }
}
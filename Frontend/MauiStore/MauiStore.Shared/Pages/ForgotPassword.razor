@page "/Olvide"
@using MudBlazor
@using CbEnLinea.Api.Common.Dtos
@using MauiStore.Shared.Services
@using Microsoft.AspNetCore.Components
@using Microsoft.AspNetCore.Components.Forms
@using System.ComponentModel.DataAnnotations

@inject IAuthService Auth
@inject NavigationManager Nav

<EditForm Model="@model" OnValidSubmit="@HandleSend">
    <DataAnnotationsValidator />
    <ValidationSummary />
    <MudCard Elevation="0" Class="cb-card">
        <MudCardContent>
                    <MudText Typo="Typo.h6" Style="font-weight:600;">¿Olvidaste tu contraseña?</MudText>
                    <MudText Class="mb-5" Typo="Typo.body2">
                        Ingrese su correo y le enviaremos un enlace para restablecerla.
                    </MudText>

                    <!-- Email -->
                    <MudTextField @bind-Value="model.Email"
                                  Class="mt-3"
                                  Label="Correo electrónico"
                                  Variant="Variant.Filled"
                                  Margin="Margin.Dense"
                                  Required="true"
                                  For="@(() => model.Email)"
                                  Adornment="Adornment.Start"
                                  AdornmentColor="Color.Primary"
                                  AdornmentIcon="@Icons.Material.Outlined.Email" />

                    <MudButton Disabled="@loading" Class="my-4 py-2 rounded-lg"
                               Color="Color.Primary" FullWidth="true" Variant="Variant.Filled"
                               ButtonType="ButtonType.Submit">
                        @(loading ? "Enviando..." : "Enviar instrucciones")
                    </MudButton>

                    @if (!string.IsNullOrWhiteSpace(error))
                    {
                        <MudAlert Severity="Severity.Error" Dense="true" Class="mt-2">@error</MudAlert>
                    }
                    @if (!string.IsNullOrWhiteSpace(success))
                    {
                        <MudAlert Severity="Severity.Success" Dense="true" Class="mt-2">@success</MudAlert>
                    }

                    <MudDivider Class="my-3" />

                    <MudStack Row="true" Spacing="2">
                        <MudButton Disabled="@loading" Variant="Variant.Outlined" Color="Color.Primary" OnClick="GoToLogin">
                            Volver a Ingreso
                        </MudButton>
                    </MudStack>

                </MudCardContent>
            </MudCard>
        @* </MudItem>
    </MudGrid> *@
</EditForm>

@code {
    private readonly ForgotVm model = new();

    private bool loading;
    private string? error;
    private string? success;

    private async Task HandleSend()
    {
        error = null; success = null; loading = true;

        try
        {
            using var cts = new CancellationTokenSource(TimeSpan.FromSeconds(20));
            var email = model.Email?.Trim() ?? string.Empty;

            var (ok, err, resp) = await Auth.ForgotPasswordAsync(email, cts.Token);

            if (ok)
            {
                success = resp?.Message ?? "Si el correo existe, se enviaron las instrucciones.";
            }
            else
            {
                error = string.IsNullOrWhiteSpace(err) ? "No se pudo enviar las instrucciones." : err;
            }
        }
        catch (OperationCanceledException)
        {
            error = "La solicitud tardó demasiado (timeout después de 20 segundos).";
        }
        catch (Exception ex)
        {
            error = $"Error inesperado: {ex.Message}";
        }
        finally
        {
            loading = false;
        }
    }

    private void GoToLogin() => Nav.NavigateTo("/");

    private sealed class ForgotVm
    {
        [Required, EmailAddress]
        public string Email { get; set; } = string.Empty;
    }
}
